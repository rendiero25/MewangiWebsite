# Salin ke .env dan isi nilai. Jangan commit file .env.

# MongoDB
MONGODB_URI=

# Server
PORT=3000
NODE_ENV=development

# URL frontend (CORS, Socket.IO, link verifikasi email / reset password, sitemap)
# Lokal:     http://localhost:5173
# Hostinger: https://mewangi.id (tanpa slash di akhir)
FRONTEND_URL=http://localhost:5173

# Origin tambahan untuk CORS/Socket (pisahkan koma), mis. jika www terpisah:
# CORS_ORIGINS=https://www.mewangi.id
CORS_ORIGINS=

# Cloudinary (gambar: avatar, artikel, review, forum, parfum — URL absolut, jalan di lokal & production)
# Salin dari dashboard Cloudinary → API Environment variable, format:
# CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>
# Alternatif: CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET
CLOUDINARY_URL=

# JWT
JWT_SECRET=
JWT_EXPIRE=7d

# Email (verifikasi / reset password)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
